@page "/contacts"
@attribute [Authorize]
@rendermode InteractiveServer

@using CRM.Core.Contacts.Abstractions
@using CRM.Core.Contacts.Domain

@inject IContactService ContactService
@inject NavigationManager Navigation

<PageTitle>Contacts - 101CRM</PageTitle>

<section class="contacts-page">
    <div class="crm-card contacts-toolbar">
        <div class="contacts-search">
            <div class="input-group">
                <span class="input-group-text">
                    <span class="material-symbols-outlined">search</span>
                </span>

                <input id="contactSearch"
                       class="form-control"
                       placeholder="Search contacts, companies, email or phone..."
                       @bind="strSearch"
                       @bind:event="oninput" />
            </div>
        </div>

        <div class="contacts-filters">
            <div class="form-check form-switch">
                <input id="includeArchived"
                       class="form-check-input"
                       type="checkbox"
                       @bind="blnIncludeArchived"
                       @bind:after="LoadContactsAsync" />
                <label class="form-check-label" for="includeArchived">Include archived</label>
            </div>
        </div>

        <div class="contacts-toolbar-actions">
            <button class="btn btn-primary" type="button" @onclick="SearchAsync">
                <span class="material-symbols-outlined">search</span>
                Search
            </button>
        </div>
    </div>

    <div class="contacts-summary row g-3">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="contacts-summary-card contacts-summary-card-primary">
                <span class="material-symbols-outlined">groups</span>

                <div>
                    <small>Active shown</small>
                    <strong>@intActiveContacts</strong>
                    <span class="contacts-summary-note">
                        @intTotalContacts total result@(GetPlural(intTotalContacts))
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="contacts-summary-card contacts-summary-card-success">
                <span class="material-symbols-outlined">alternate_email</span>

                <div>
                    <small>Contactable</small>
                    <strong>@intContactableContacts</strong>
                    <span class="contacts-summary-note">
                        @intContactablePercentage% have email or phone
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="contacts-summary-card contacts-summary-card-info">
                <span class="material-symbols-outlined">apartment</span>

                <div>
                    <small>Linked to companies</small>
                    <strong>@intLinkedContacts</strong>
                    <span class="contacts-summary-note">
                        @intLinkedPercentage% are attached to a company
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="contacts-summary-card contacts-summary-card-warning">
                <span class="material-symbols-outlined">priority_high</span>

                <div>
                    <small>Needs details</small>
                    <strong>@intNeedsDetailsContacts</strong>
                    <span class="contacts-summary-note">
                        Missing company or contact details
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (blnShowErrorAlert && !String.IsNullOrWhiteSpace(strErrorMessage))
    {
        <div class="alert alert-danger contacts-alert" role="alert">
            <span class="material-symbols-outlined">error</span>

            <div class="alert-content">
                <strong class="alert-title">Unable to load contacts</strong>
                <p>@strErrorMessage</p>
            </div>

            <div class="alert-actions">
                <button class="btn btn-soft-danger btn-sm" type="button" @onclick="LoadContactsAsync">
                    <span class="material-symbols-outlined">refresh</span>
                    Try again
                </button>

                <button class="btn btn-soft-danger btn-sm contacts-alert-close" type="button" @onclick="DismissErrorAlert">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
        </div>
    }

    <div class="crm-card">
        <div class="crm-card-header">
            <div>
                <h3>Contact records</h3>
                <p>@strResultSummary</p>
            </div>

            @if (!String.IsNullOrWhiteSpace(strSearch))
            {
                <button class="btn btn-soft-secondary btn-sm" type="button" @onclick="ClearSearchAsync">
                    <span class="material-symbols-outlined">filter_alt_off</span>
                    Clear search
                </button>
            }
        </div>

        @if (blnLoading)
        {
            <div class="crm-loading">
                <span class="spinner-border spinner-border-sm"></span>
                Loading contacts...
            </div>
        }
        else if (!colContacts.Any())
        {
            <div class="crm-empty-state">
                <span class="material-symbols-outlined">contacts</span>
                <h4>No contacts found</h4>
                <p>Add your first contact or adjust the search filters.</p>

                <a class="btn btn-primary" href="/contacts/add">
                    <span class="material-symbols-outlined">person_add</span>
                    Add contact
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle crm-table contacts-table">
                    <thead>
                        <tr>
                            <th>Contact</th>
                            <th>Company</th>
                            <th>Role</th>
                            <th>Contact details</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (Contact objContact in colContacts)
                        {
                            <tr class="@GetContactRowClass(objContact)">
                                <td>
                                    <div class="contacts-person-cell">
                                        <div class="contacts-avatar">
                                            @GetInitials(objContact)
                                        </div>

                                        <div>
                                            <a class="contacts-name-link" href="@GetContactUrl(objContact.Id)">
                                                @GetContactName(objContact)
                                            </a>

                                            @if (!String.IsNullOrWhiteSpace(objContact.Department))
                                            {
                                                <small class="d-block text-muted">
                                                    @objContact.Department
                                                </small>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    @if (objContact.Company != null)
                                    {
                                        <a class="contacts-company-link" href="@GetCompanyUrl(objContact.Company.Id)">
                                            @objContact.Company.Name
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not linked</span>
                                    }
                                </td>

                                <td>@DisplayValue(objContact.JobTitle)</td>

                                <td>
                                    @if (!String.IsNullOrWhiteSpace(objContact.PrimaryEmail))
                                    {
                                        <a href="mailto:@objContact.PrimaryEmail">@objContact.PrimaryEmail</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }

                                    @if (!String.IsNullOrWhiteSpace(GetBestPhoneNumber(objContact)))
                                    {
                                        <small class="d-block text-muted">
                                            @GetBestPhoneNumber(objContact)
                                        </small>
                                    }
                                </td>

                                <td>
                                    @if (objContact.Entity.ArchivedUtc.HasValue)
                                    {
                                        <span class="badge text-bg-secondary">Archived</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">Active</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="contacts-row-actions">
                                        <a href="@GetContactUrl(objContact.Id)" class="btn btn-soft-primary btn-sm">
                                            <span class="material-symbols-outlined">visibility</span>
                                            View
                                        </a>

                                        <a href="@($"/contacts/{objContact.Id}/edit")" class="btn btn-soft-secondary btn-sm">
                                            <span class="material-symbols-outlined">edit</span>
                                            Edit
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@code {
    private List<Contact> colContacts = [];

    private String? strSearch;
    private String? strErrorMessage;
    private String strResultSummary = "Showing active contact records.";

    private Boolean blnIncludeArchived;
    private Boolean blnLoading = true;
    private Boolean blnShowErrorAlert = true;

    private Int32 intTotalContacts;
    private Int32 intActiveContacts;
    private Int32 intArchivedContacts;
    private Int32 intContactableContacts;
    private Int32 intContactablePercentage;
    private Int32 intLinkedContacts;
    private Int32 intLinkedPercentage;
    private Int32 intNeedsDetailsContacts;

    protected override async Task OnInitializedAsync()
    {
        HeaderState.SetHeader(
            "Contacts",
            "Manage people, decision makers and customer relationships.",
            @<a class="btn btn-primary" href="/contacts/add">
                <span class="material-symbols-outlined">person_add</span>
                Add contact
            </a>);

        await LoadContactsAsync();
    }

    private Task SearchAsync()
    {
        return LoadContactsAsync();
    }

    private async Task LoadContactsAsync()
    {
        blnLoading = true;
        strErrorMessage = null;
        blnShowErrorAlert = true;

        try
        {
            colContacts = await ContactService.GetContactsAsync(
                strSearch,
                null,
                blnIncludeArchived,
                false);

            SetContactStats();
            SetResultSummary();
        }
        catch (Exception objError)
        {
            strErrorMessage = "We couldn’t retrieve the contact records right now. " + objError.Message;

            colContacts = [];

            intTotalContacts = 0;
            intActiveContacts = 0;
            intArchivedContacts = 0;
            intContactableContacts = 0;
            intContactablePercentage = 0;
            intLinkedContacts = 0;
            intLinkedPercentage = 0;
            intNeedsDetailsContacts = 0;

            SetResultSummary();
        }
        finally
        {
            blnLoading = false;
        }
    }

    private async Task ClearSearchAsync()
    {
        strSearch = null;
        await LoadContactsAsync();
    }

    private void DismissErrorAlert()
    {
        blnShowErrorAlert = false;
    }

    private void SetContactStats()
    {
        intTotalContacts = colContacts.Count;

        intArchivedContacts = colContacts.Count(objContact =>
            objContact.Entity.ArchivedUtc.HasValue);

        intActiveContacts = colContacts.Count(objContact =>
            !objContact.Entity.ArchivedUtc.HasValue);

        intContactableContacts = colContacts.Count(HasPrimaryContactDetails);

        intLinkedContacts = colContacts.Count(objContact =>
            objContact.Company != null);

        intNeedsDetailsContacts = colContacts.Count(objContact =>
            !objContact.Entity.ArchivedUtc.HasValue &&
            (
                objContact.Company == null ||
                !HasPrimaryContactDetails(objContact)
            ));

        intContactablePercentage = intTotalContacts == 0
            ? 0
            : (Int32)Math.Round((Decimal)intContactableContacts / intTotalContacts * 100);

        intLinkedPercentage = intTotalContacts == 0
            ? 0
            : (Int32)Math.Round((Decimal)intLinkedContacts / intTotalContacts * 100);
    }

    private void SetResultSummary()
    {
        if (String.IsNullOrWhiteSpace(strSearch))
        {
            strResultSummary = $"Showing {intTotalContacts} contact record{GetPlural(intTotalContacts)}.";
            return;
        }

        strResultSummary = $"Showing {intTotalContacts} result{GetPlural(intTotalContacts)} for \"{strSearch}\".";
    }

    private static String GetPlural(Int32 intCount)
    {
        return intCount == 1 ? String.Empty : "s";
    }

    private static String GetContactUrl(Guid objContactId)
    {
        return $"/contacts/{objContactId}";
    }

    private static String GetCompanyUrl(Guid objCompanyId)
    {
        return $"/companies/{objCompanyId}";
    }

    private static String GetContactName(Contact objContact)
    {
        String strName = $"{objContact.FirstName} {objContact.LastName}".Trim();

        if (!String.IsNullOrWhiteSpace(strName))
        {
            return strName;
        }

        if (!String.IsNullOrWhiteSpace(objContact.PrimaryEmail))
        {
            return objContact.PrimaryEmail;
        }

        if (!String.IsNullOrWhiteSpace(objContact.PrimaryPhone))
        {
            return objContact.PrimaryPhone;
        }

        if (!String.IsNullOrWhiteSpace(objContact.MobilePhone))
        {
            return objContact.MobilePhone;
        }

        return "Unnamed contact";
    }

    private static String GetInitials(Contact objContact)
    {
        String strFirst = !String.IsNullOrWhiteSpace(objContact.FirstName)
            ? objContact.FirstName[..1]
            : String.Empty;

        String strLast = !String.IsNullOrWhiteSpace(objContact.LastName)
            ? objContact.LastName[..1]
            : String.Empty;

        String strInitials = $"{strFirst}{strLast}".Trim();

        if (!String.IsNullOrWhiteSpace(strInitials))
        {
            return strInitials.ToUpperInvariant();
        }

        String strName = GetContactName(objContact);

        return strName[..1].ToUpperInvariant();
    }

    private static Boolean HasPrimaryContactDetails(Contact objContact)
    {
        return !String.IsNullOrWhiteSpace(objContact.PrimaryEmail) ||
               !String.IsNullOrWhiteSpace(objContact.PrimaryPhone) ||
               !String.IsNullOrWhiteSpace(objContact.MobilePhone);
    }

    private static String? GetBestPhoneNumber(Contact objContact)
    {
        if (!String.IsNullOrWhiteSpace(objContact.PrimaryPhone))
        {
            return objContact.PrimaryPhone;
        }

        if (!String.IsNullOrWhiteSpace(objContact.MobilePhone))
        {
            return objContact.MobilePhone;
        }

        return null;
    }

    private static String DisplayValue(String? strValue)
    {
        if (String.IsNullOrWhiteSpace(strValue))
        {
            return "—";
        }

        return strValue;
    }

    private static String GetContactRowClass(Contact objContact)
    {
        if (objContact.Entity.ArchivedUtc.HasValue)
        {
            return "contacts-row-archived";
        }

        return String.Empty;
    }
}