@page "/opportunities/add"
@page "/opportunities/{OpportunityId:guid}/edit"
@attribute [Authorize]
@rendermode InteractiveServer

@using CRM.Core.Companies.Abstractions
@using CRM.Core.Companies.Domain
@using CRM.Core.Contacts.Abstractions
@using CRM.Core.Contacts.Domain
@using CRM.Core.Opportunities.Abstractions
@using CRM.Core.Opportunities.Domain
@using CRM.Web.State

@inject IOpportunityService OpportunityService
@inject ICompanyService CompanyService
@inject IContactService ContactService
@inject NavigationManager Navigation
@inject PageHeaderState HeaderState

<PageTitle>@strPageTitle</PageTitle>

<section class="opportunity-edit-page">
    <div class="opportunity-toolbar">
        <button type="button" class="btn crm-btn-secondary" @onclick="GoBack">
            <span class="material-symbols-outlined">arrow_back</span>
            @(blnEditMode ? "Back to opportunity" : "Back to opportunities")
        </button>
    </div>

    @if (!String.IsNullOrWhiteSpace(strErrorMessage))
    {
        <div class="alert alert-danger crm-alert" role="alert">
            <span class="material-symbols-outlined">error</span>
            <div>@strErrorMessage</div>
        </div>
    }

    @if (blnLoading)
    {
        <div class="crm-card opportunity-empty-state">
            <span class="material-symbols-outlined">hourglass_empty</span>
            <h2>Loading opportunity</h2>
            <p>Please wait while the form is prepared.</p>
        </div>
    }
    else
    {
        <EditForm Model="objOpportunity" OnValidSubmit="SaveOpportunityAsync" FormName="OpportunityEditForm">
            <DataAnnotationsValidator />

            <div class="opportunity-layout">
                <div class="opportunity-main-column">
                    <div class="crm-card opportunity-form-card">
                        <h2>@(blnEditMode ? "Edit opportunity" : "New opportunity")</h2>
                        <p>Track the deal, company, contact and pipeline stage.</p>

                        <div class="row g-3 mt-1">
                            <div class="col-md-8">
                                <label class="form-label" for="name">Name</label>
                                <InputText id="name" class="form-control" @bind-Value="objOpportunity.Name" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="stage">Stage</label>
                                <InputSelect id="stage" class="form-select" TValue="OpportunityStage" @bind-Value="objOpportunity.Stage">
                                    @foreach (OpportunityStage enmStage in Enum.GetValues<OpportunityStage>())
                                    {
                                        <option value="@enmStage">@GetStageName(enmStage)</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label" for="company">Company</label>
                                <select id="company" class="form-select" @bind="strSelectedCompanyId">
                                    <option value="">No company linked</option>

                                    @foreach (Company objCompany in colCompanies)
                                    {
                                        <option value="@objCompany.Id.ToString()">@objCompany.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label" for="contact">Contact</label>
                                <select id="contact" class="form-select" @bind="strSelectedContactId">
                                    <option value="">No contact linked</option>

                                    @foreach (Contact objContact in colContacts)
                                    {
                                        <option value="@objContact.Id.ToString()">@objContact.Entity.DisplayName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="value">Value</label>
                                <InputNumber id="value" class="form-control" @bind-Value="objOpportunity.Value" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="probability">Probability %</label>
                                <InputNumber id="probability" class="form-control" @bind-Value="objOpportunity.ProbabilityPercent" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="closeDate">Expected close date</label>
                                <InputDate id="closeDate" class="form-control" @bind-Value="objOpportunity.ExpectedCloseDateUtc" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label" for="source">Source</label>
                                <InputText id="source" class="form-control" @bind-Value="objOpportunity.Source" />
                            </div>

                            <div class="col-12">
                                <label class="form-label" for="description">Description</label>
                                <InputTextArea id="description" class="form-control opportunity-textarea" @bind-Value="objOpportunity.Description" />
                            </div>

                            <div class="col-12">
                                <label class="form-label" for="notes">Notes</label>
                                <InputTextArea id="notes" class="form-control opportunity-textarea" @bind-Value="objOpportunity.Notes" />
                            </div>
                        </div>
                    </div>

                    <div class="opportunity-save-bar">
                        <button type="button" class="btn crm-btn-secondary" disabled="@blnSaving" @onclick="GoBack">
                            Cancel
                        </button>

                        <button type="submit" class="btn crm-btn-primary" disabled="@blnSaving">
                            <span class="material-symbols-outlined">save</span>
                            @(blnSaving ? "Saving..." : "Save opportunity")
                        </button>
                    </div>
                </div>

                <aside class="opportunity-side-column">
                    <div class="crm-card opportunity-summary-card">
                        <h3>Preview</h3>

                        <dl>
                            <div>
                                <dt>Stage</dt>
                                <dd>@GetStageName(objOpportunity.Stage)</dd>
                            </div>

                            <div>
                                <dt>Value</dt>
                                <dd>@FormatMoney(objOpportunity.Value)</dd>
                            </div>

                            <div>
                                <dt>Probability</dt>
                                <dd>@FormatProbability(objOpportunity.ProbabilityPercent)</dd>
                            </div>

                            <div>
                                <dt>Close</dt>
                                <dd>@FormatDate(objOpportunity.ExpectedCloseDateUtc)</dd>
                            </div>
                        </dl>
                    </div>
                </aside>
            </div>
        </EditForm>
    }
</section>

@code {
    [Parameter]
    public Guid? OpportunityId { get; set; }

    [SupplyParameterFromQuery(Name = "companyId")]
    public Guid? CompanyId { get; set; }

    [SupplyParameterFromQuery(Name = "contactId")]
    public Guid? ContactId { get; set; }

    private Opportunity objOpportunity = new();
    private List<Company> colCompanies = [];
    private List<Contact> colContacts = [];

    private String strPageTitle = "New opportunity";
    private String? strErrorMessage;
    private Boolean blnLoading = true;
    private Boolean blnSaving;

    private Boolean blnEditMode => OpportunityId.HasValue && OpportunityId.Value != Guid.Empty;

    private String strSelectedCompanyId
    {
        get => objOpportunity.CompanyId?.ToString() ?? String.Empty;
        set
        {
            objOpportunity.CompanyId = Guid.TryParse(value, out Guid objCompanyId)
                ? objCompanyId
                : null;
        }
    }

    private String strSelectedContactId
    {
        get => objOpportunity.ContactId?.ToString() ?? String.Empty;
        set
        {
            objOpportunity.ContactId = Guid.TryParse(value, out Guid objContactId)
                ? objContactId
                : null;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        blnLoading = true;
        strErrorMessage = null;

        try
        {
            colCompanies = await CompanyService.GetCompaniesAsync();
            colContacts = await ContactService.GetContactsAsync();

            if (blnEditMode)
            {
                Opportunity? objExistingOpportunity = await OpportunityService.GetOpportunityByIdAsync(OpportunityId!.Value);

                if (objExistingOpportunity == null)
                {
                    strErrorMessage = "Opportunity not found.";
                    HeaderState.SetHeader("Opportunity not found", "The selected opportunity could not be loaded");
                    return;
                }

                objOpportunity = objExistingOpportunity;
                strPageTitle = "Edit " + objOpportunity.Name;
                HeaderState.SetHeader("Edit opportunity", objOpportunity.Name);
            }
            else
            {
                objOpportunity = new Opportunity
                {
                    CompanyId = CompanyId,
                    ContactId = ContactId,
                    Stage = OpportunityStage.New
                };

                strPageTitle = "New opportunity";
                HeaderState.SetHeader("New opportunity", "Create a new sales opportunity");
            }
        }
        catch (Exception objError)
        {
            strErrorMessage = "Failed to load opportunity form: " + objError.Message;
        }
        finally
        {
            blnLoading = false;
        }
    }

    private async Task SaveOpportunityAsync()
    {
        blnSaving = true;
        strErrorMessage = null;

        try
        {
            Opportunity objSavedOpportunity;

            if (blnEditMode)
            {
                Opportunity? objUpdatedOpportunity = await OpportunityService.UpdateOpportunityAsync(objOpportunity);

                if (objUpdatedOpportunity == null)
                {
                    strErrorMessage = "The opportunity could not be updated.";
                    return;
                }

                objSavedOpportunity = objUpdatedOpportunity;
            }
            else
            {
                objSavedOpportunity = await OpportunityService.AddOpportunityAsync(objOpportunity);
            }

            Navigation.NavigateTo($"/opportunities/{objSavedOpportunity.Id}");
        }
        catch (Exception objError)
        {
            strErrorMessage = "Failed to save opportunity: " + objError.Message;
        }
        finally
        {
            blnSaving = false;
        }
    }

    private void GoBack()
    {
        if (blnEditMode)
        {
            Navigation.NavigateTo($"/opportunities/{OpportunityId}");
            return;
        }

        Navigation.NavigateTo("/opportunities");
    }

    private static String GetStageName(OpportunityStage enmStage)
    {
        return enmStage switch
        {
            OpportunityStage.New => "New",
            OpportunityStage.Qualified => "Qualified",
            OpportunityStage.Proposal => "Proposal",
            OpportunityStage.Negotiation => "Negotiation",
            OpportunityStage.Won => "Won",
            OpportunityStage.Lost => "Lost",
            _ => enmStage.ToString()
        };
    }

    private static String FormatMoney(Decimal? dcmValue)
    {
        return dcmValue.HasValue ? dcmValue.Value.ToString("C0") : "Not set";
    }

    private static String FormatProbability(Int32? intProbability)
    {
        return intProbability.HasValue ? $"{intProbability.Value}%" : "Not set";
    }

    private static String FormatDate(DateTime? dteDate)
    {
        return dteDate.HasValue ? dteDate.Value.ToLocalTime().ToString("dd MMM yyyy") : "Not set";
    }
}