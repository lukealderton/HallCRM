<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="stylesheet" href="@Assets["CRM.Web.styles.css"]" />
    <link rel="icon" type="image/png" href="favicon.png" />

    @* WebFonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    <ImportMap />
    <AuthorizeView>
        <Authorized>
            <HeadOutlet @rendermode="@objPageRenderMode" />
        </Authorized>
        <NotAuthorized>
            <HeadOutlet />
        </NotAuthorized>
    </AuthorizeView>
</head>

<body>
    <CascadingAuthenticationState>
        <AuthorizeView>
            <Authorized>
                <Routes @rendermode="@objPageRenderMode" />
            </Authorized>
            <NotAuthorized>
                <Routes />
            </NotAuthorized>
        </AuthorizeView>
    </CascadingAuthenticationState>
    <CRM.Web.Components.Shared.Toasts />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private IComponentRenderMode? objPageRenderMode =>
        HttpContext.AcceptsInteractiveRouting()
            ? InteractiveServer
            : null;
}