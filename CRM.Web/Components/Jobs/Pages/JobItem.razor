@page "/opportunities/{OpportunityId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer

@using CRM.Core.Jobs.Abstractions
@using CRM.Core.Jobs.Domain
@using CRM.Web.State

@inject IJobService JobService
@inject NavigationManager Navigation
@inject PageHeaderState HeaderState

<PageTitle>@strPageTitle - 101CRM</PageTitle>

<section class="opportunity-item-page">
    @if (!String.IsNullOrWhiteSpace(strSuccessMessage))
    {
        <div class="alert alert-success opportunity-alert" role="alert">
            <span class="material-symbols-outlined">check_circle</span>

            <div class="alert-content">
                <strong class="alert-title">@strSuccessMessage</strong>
                <p>The opportunity record has been updated.</p>
            </div>
        </div>
    }

    @if (!String.IsNullOrWhiteSpace(strErrorMessage))
    {
        <div class="alert alert-danger opportunity-alert" role="alert">
            <span class="material-symbols-outlined">error</span>

            <div class="alert-content">
                <strong class="alert-title">Unable to update opportunity</strong>
                <p>@strErrorMessage</p>
            </div>
        </div>
    }

    @if (blnConfirmArchive)
    {
        <div class="alert alert-warning opportunity-alert">
            <span class="material-symbols-outlined">archive</span>

            <div class="alert-content">
                <strong class="alert-title">Archive this job?</strong>
                <p>Archived jobs are hidden from normal pipeline views but can be restored later.</p>
            </div>

            <div class="alert-actions">
                <button class="btn btn-soft-danger btn-sm" type="button" @onclick="ArchiveJobAsync" disabled="@blnSaving">
                    Archive job
                </button>

                <button class="btn btn-soft-secondary btn-sm" type="button" @onclick="CancelActions">
                    Cancel
                </button>
            </div>
        </div>
    }

    @if (blnConfirmDelete)
    {
        <div class="alert alert-danger opportunity-alert">
            <span class="material-symbols-outlined">delete</span>

            <div class="alert-content">
                <strong class="alert-title">Delete this job?</strong>
                <p>This will mark the job as deleted. It will no longer appear in normal job lists.</p>
            </div>

            <div class="alert-actions">
                <button class="btn btn-soft-danger btn-sm" type="button" @onclick="DeleteJobAsync" disabled="@blnSaving">
                    Delete job
                </button>

                <button class="btn btn-soft-secondary btn-sm" type="button" @onclick="CancelActions">
                    Cancel
                </button>
            </div>
        </div>
    }

    @if (blnLoading)
    {
        <div class="crm-card">
            <div class="crm-loading">
                <span class="spinner-border spinner-border-sm"></span>
                Loading opportunity...
            </div>
        </div>
    }
    else if (objJob == null)
    {
        <div class="alert alert-danger opportunity-alert" role="alert">
            <span class="material-symbols-outlined">search_off</span>

            <div class="alert-content">
                <strong class="alert-title">Job not found</strong>
                <p>This job may have been deleted or moved.</p>
            </div>
        </div>
    }
    else
    {
        <div class="opportunity-profile-card crm-card">
            <div class="opportunity-profile-main">
                <div class="opportunity-avatar">
                    @GetJobInitial(objJob)
                </div>

                <div>
                    <div class="opportunity-title-row">
                        <h2>@objJob.Name</h2>

                        <span class="@GetStageBadgeClass(objJob.Stage)">
                            @objJob.Stage.GetDisplay().Name
                        </span>

                        @if (objJob.Entity.ArchivedUtc.HasValue)
                        {
                            <span class="badge text-bg-secondary">Archived</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                    </div>

                    <p class="opportunity-subtitle">
                        @(objJob.Company?.Name ?? "No company linked")
                    </p>

                    <div class="opportunity-meta-row">
                        <span>
                            <span class="material-symbols-outlined">payments</span>
                            @FormatMoney(objJob.Value)
                        </span>

                        <span>
                            <span class="material-symbols-outlined">percent</span>
                            @FormatProbability(objJob.ProbabilityPercent)
                        </span>

                        <span>
                            <span class="material-symbols-outlined">event</span>
                            @FormatDate(objJob.ExpectedCloseDateUtc)
                        </span>
                    </div>
                </div>
            </div>

            <div class="opportunity-profile-actions">
                <button type="button" class="btn btn-primary" @onclick="GoToEdit">
                    <span class="material-symbols-outlined">edit</span>
                    Edit job
                </button>

                @if (objJob.Entity.ArchivedUtc.HasValue)
                {
                    <button type="button" class="btn btn-soft-primary" disabled="@blnSaving" @onclick="RestoreJobAsync">
                        <span class="material-symbols-outlined">unarchive</span>
                        Restore
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-soft-secondary" disabled="@blnSaving" @onclick="ShowArchiveConfirmation">
                        <span class="material-symbols-outlined">archive</span>
                        Archive
                    </button>
                }

                <button type="button" class="btn btn-soft-danger" disabled="@blnSaving" @onclick="ShowDeleteConfirmation">
                    <span class="material-symbols-outlined">delete</span>
                    Delete
                </button>
            </div>
        </div>

        <div class="opportunity-layout">
            <div class="opportunity-main-column">
                <div class="crm-card">
                    <div class="crm-card-header">
                        <div>
                            <h3>Opportunity details</h3>
                            <p>Value, probability, source and expected close date.</p>
                        </div>
                    </div>

                    <div class="opportunity-card-body">
                        <div class="opportunity-details-grid">
                            <div class="opportunity-detail-item">
                                <span class="material-symbols-outlined">payments</span>

                                <div>
                                    <small>Value</small>
                                    <strong>@FormatMoney(objJob.Value)</strong>
                                </div>
                            </div>

                            <div class="opportunity-detail-item">
                                <span class="material-symbols-outlined">percent</span>

                                <div>
                                    <small>Probability</small>
                                    <strong>@FormatProbability(objJob.ProbabilityPercent)</strong>
                                </div>
                            </div>

                            <div class="opportunity-detail-item">
                                <span class="material-symbols-outlined">event</span>

                                <div>
                                    <small>Expected close</small>
                                    <strong>@FormatDate(objJob.ExpectedCloseDateUtc)</strong>
                                </div>
                            </div>

                            <div class="opportunity-detail-item">
                                <span class="material-symbols-outlined">campaign</span>

                                <div>
                                    <small>Source</small>
                                    <strong>@DisplayValue(objJob.Source)</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="crm-card">
                    <div class="crm-card-header">
                        <div>
                            <h3>Description</h3>
                            <p>Summary and context for this job.</p>
                        </div>
                    </div>

                    <div class="opportunity-card-body">
                        @if (!String.IsNullOrWhiteSpace(objJob.Description))
                        {
                            <p class="opportunity-description">@objJob.Description</p>
                        }
                        else
                        {
                            <div class="opportunity-muted-panel">
                                <span class="material-symbols-outlined">notes</span>
                                <span>No description has been added yet.</span>
                            </div>
                        }
                    </div>
                </div>

                <EntityNotes EntityId="@JobId"
                             Title="Notes"
                             Subtitle="Internal notes for this job."
                             EmptyText="No notes have been added for this job yet." />
            </div>

            <aside class="opportunity-side-column">
                <div class="crm-card">
                    <div class="opportunity-card-body">
                        <h4 class="opportunity-side-heading">Quick actions</h4>

                        <div class="opportunity-action-list">
                            @if (objJob.Company != null)
                            {
                                <a href="@GetCompanyUrl(objJob.Company.Id)" class="btn btn-soft-primary w-100">
                                    <span class="material-symbols-outlined">business</span>
                                    Open company
                                </a>
                            }

                            @if (objJob.Contact != null)
                            {
                                <a href="@GetContactUrl(objJob.Contact.Id)" class="btn btn-soft-secondary w-100">
                                    <span class="material-symbols-outlined">person</span>
                                    Open contact
                                </a>
                            }

                            <button type="button" class="btn btn-soft-secondary w-100" @onclick="GoToEdit">
                                <span class="material-symbols-outlined">edit</span>
                                Edit details
                            </button>
                        </div>
                    </div>
                </div>

                <div class="crm-card">
                    <div class="opportunity-card-body">
                        <h4 class="opportunity-side-heading">Overview</h4>

                        <div class="opportunity-meta-list">
                            <div>
                                <span>Company</span>

                                @if (objJob.Company != null)
                                {
                                    <strong>
                                        <a href="@GetCompanyUrl(objJob.Company.Id)">
                                            @objJob.Company.Name
                                        </a>
                                    </strong>
                                }
                                else
                                {
                                    <strong>-</strong>
                                }
                            </div>

                            <div>
                                <span>Contact</span>

                                @if (objJob.Contact != null)
                                {
                                    <strong>
                                        <a href="@GetContactUrl(objJob.Contact.Id)">
                                            @objJob.Contact.Entity.DisplayName
                                        </a>
                                    </strong>
                                }
                                else
                                {
                                    <strong>-</strong>
                                }
                            </div>

                            <div>
                                <span>Stage</span>
                                <strong>@objJob.Stage.GetDisplay().Name</strong>
                            </div>

                            <div>
                                <span>Source</span>
                                <strong>@DisplayValue(objJob.Source)</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="crm-card">
                    <div class="opportunity-card-body">
                        <h4 class="opportunity-side-heading">Record details</h4>

                        <div class="opportunity-meta-list">
                            <div>
                                <span>Created</span>
                                <strong>@FormatNullableDate(objJob.Entity.CreatedUtc)</strong>
                            </div>

                            <div>
                                <span>Updated</span>
                                <strong>@FormatNullableDate(objJob.Entity.UpdatedUtc)</strong>
                            </div>

                            <div>
                                <span>Archived</span>
                                <strong>@FormatNullableDate(objJob.Entity.ArchivedUtc)</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    }
</section>

@code {
    [Parameter]
    public Guid JobId { get; set; }

    private Job? objJob;

    private String strPageTitle = "Job";
    private String? strSuccessMessage;
    private String? strErrorMessage;

    private Boolean blnLoading = true;
    private Boolean blnSaving;
    private Boolean blnConfirmArchive;
    private Boolean blnConfirmDelete;

    protected override async Task OnParametersSetAsync()
    {
        await LoadJobAsync();
    }

    private RenderFragment GetHeaderActions()
    {
        return @<a href="/jobs" class="btn btn-soft-secondary">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to jobs
        </a>;
    }

    private async Task LoadJobAsync()
    {
        blnLoading = true;
        strErrorMessage = null;
        strSuccessMessage = null;
        blnConfirmArchive = false;
        blnConfirmDelete = false;

        HeaderState.SetHeader(
            "Job",
            "Loading job...",
            GetHeaderActions());

        try
        {
            objJob = await JobService.GetJobByIdAsync(JobId);

            if (objJob == null)
            {
                strPageTitle = "Job not found";

                HeaderState.SetHeader(
                    "Job not found",
                    "The selected job could not be loaded",
                    GetHeaderActions());

                return;
            }

            strPageTitle = objJob.Name;

            HeaderState.SetHeader(
                objJob.Name,
                objJob.Company?.Name ?? "Job details",
                GetHeaderActions());
        }
        catch (Exception objError)
        {
            strErrorMessage = "Failed to load job: " + objError.Message;

            HeaderState.SetHeader(
                "Job",
                "Unable to load job",
                GetHeaderActions());
        }
        finally
        {
            blnLoading = false;
        }
    }

    private void GoToEdit()
    {
        Navigation.NavigateTo($"/jobs/{JobId}/edit");
    }

    private void ShowArchiveConfirmation()
    {
        blnConfirmArchive = true;
        blnConfirmDelete = false;
        strSuccessMessage = null;
        strErrorMessage = null;
    }

    private void ShowDeleteConfirmation()
    {
        blnConfirmDelete = true;
        blnConfirmArchive = false;
        strSuccessMessage = null;
        strErrorMessage = null;
    }

    private void CancelActions()
    {
        blnConfirmArchive = false;
        blnConfirmDelete = false;
    }

    private async Task ArchiveJobAsync()
    {
        await RunJobActionAsync(
            () => JobService.ArchiveJobAsync(JobId),
            "Job archived");
    }

    private async Task RestoreJobAsync()
    {
        await RunJobActionAsync(
            () => JobService.RestoreJobAsync(JobId),
            "Job restored");
    }

    private async Task DeleteJobAsync()
    {
        blnSaving = true;
        strErrorMessage = null;
        strSuccessMessage = null;

        try
        {
            Boolean blnDeleted = await JobService.DeleteJobAsync(JobId);

            if (!blnDeleted)
            {
                strErrorMessage = "The job could not be deleted. It may already have been deleted.";
                return;
            }

            Navigation.NavigateTo("/jobs");
        }
        catch (Exception objError)
        {
            strErrorMessage = "Failed to delete job: " + objError.Message;
        }
        finally
        {
            blnSaving = false;
            blnConfirmDelete = false;
        }
    }

    private async Task RunJobActionAsync(Func<Task<Boolean>> objAction, String strSuccessMessageText)
    {
        blnSaving = true;
        strErrorMessage = null;
        strSuccessMessage = null;
        blnConfirmArchive = false;
        blnConfirmDelete = false;

        try
        {
            Boolean blnSuccess = await objAction();

            if (!blnSuccess)
            {
                strErrorMessage = "The job could not be updated. It may have been deleted or no longer exists.";
                return;
            }

            await LoadJobAsync();
            strSuccessMessage = strSuccessMessageText;
        }
        catch (Exception objError)
        {
            strErrorMessage = "Failed to update job: " + objError.Message;
        }
        finally
        {
            blnSaving = false;
        }
    }

    private static String GetCompanyUrl(Guid objCompanyId)
    {
        return $"/companies/{objCompanyId}";
    }

    private static String GetContactUrl(Guid objContactId)
    {
        return $"/contacts/{objContactId}";
    }

    private static String GetJobInitial(Job objJob)
    {
        if (String.IsNullOrWhiteSpace(objJob.Name))
        {
            return "?";
        }

        return objJob.Name.Trim().Substring(0, 1).ToUpperInvariant();
    }

    private static String GetStageBadgeClass(JobStage enmStage)
    {
        return enmStage switch
        {
            JobStage.New => "job-stage job-stage-new",
            JobStage.Lost => "job-stage job-stage-lost",
            JobStage.Quoted => "job-stage job-stage-quoted",
            JobStage.ToDo => "job-stage job-stage-todo",
            JobStage.Paid => "job-stage job-stage-paid",
            _ => "job-stage"
        };
    }

    private static String FormatMoney(Decimal? dcmValue)
    {
        return dcmValue.HasValue ? dcmValue.Value.ToString("C0") : "-";
    }

    private static String FormatProbability(Int32? intProbability)
    {
        return intProbability.HasValue ? $"{intProbability.Value}%" : "-";
    }

    private static String FormatDate(DateTime? dteDate)
    {
        return dteDate.HasValue ? dteDate.Value.ToLocalTime().ToString("dd MMM yyyy") : "-";
    }

    private static String FormatNullableDate(DateTime? dteDate)
    {
        return dteDate.HasValue ? dteDate.Value.ToLocalTime().ToString("dd MMM yyyy") : "-";
    }

    private static String DisplayValue(String? strValue)
    {
        return String.IsNullOrWhiteSpace(strValue) ? "-" : strValue;
    }
}