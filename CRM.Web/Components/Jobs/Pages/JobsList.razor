@page "/jobs"
@attribute [Authorize]
@rendermode InteractiveServer

@using CRM.Core.Jobs.Domain
@using CRM.Core.Jobs.Abstractions
@using CRM.Web.State

@inject IJobService JobService
@inject NavigationManager Navigation
@inject PageHeaderState HeaderState

<PageTitle>Jobs - 101CRM</PageTitle>

<section class="jobs-page">
    <div class="crm-card jobs-toolbar">
        <div class="jobs-search">
            <div class="input-group">
                <span class="input-group-text">
                    <span class="material-symbols-outlined">search</span>
                </span>

                <input id="jobSearch"
                       class="form-control"
                       placeholder="Search jobs, companies or contacts..."
                       @bind="strSearch"
                       @bind:event="oninput" />
            </div>
        </div>

        <div class="jobs-filters">
            <select class="form-select jobs-stage-filter"
                    @bind="strSelectedStage"
                    @bind:after="LoadJobsAsync">
                <option value="">All stages</option>

                @foreach (JobStage enmStage in Enum.GetValues<JobStage>())
                {
                    <option value="@enmStage.ToString()">@enmStage.GetDisplay().Name</option>
                }
            </select>

            <div class="jobs-filter-divider"></div>

            <div class="form-check form-switch">
                <input id="includeArchived"
                       class="form-check-input"
                       type="checkbox"
                       @bind="blnIncludeArchived"
                       @bind:after="LoadJobsAsync" />
                <label class="form-check-label" for="includeArchived">Include archived</label>
            </div>
        </div>

        <div class="jobs-toolbar-actions">
            <button class="btn btn-primary" type="button" @onclick="SearchAsync">
                <span class="material-symbols-outlined">search</span>
                Search
            </button>
        </div>
    </div>

    <div class="jobs-summary row g-3">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="jobs-summary-card jobs-summary-card-primary">
                <span class="material-symbols-outlined">track_changes</span>

                <div>
                    <small>Open shown</small>
                    <strong>@intOpenJobs</strong>
                    <span class="jobs-summary-note">
                        @intTotalJobs total result@(GetPlural(intTotalJobs))
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="jobs-summary-card jobs-summary-card-success">
                <span class="material-symbols-outlined">payments</span>

                <div>
                    <small>Open pipeline</small>
                    <strong>@FormatMoney(dcmOpenPipelineValue)</strong>
                    <span class="jobs-summary-note">
                        Active non-won/lost value
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="jobs-summary-card jobs-summary-card-warning">
                <span class="material-symbols-outlined">event_upcoming</span>

                <div>
                    <small>Closing soon</small>
                    <strong>@intClosingSoonJobs</strong>
                    <span class="jobs-summary-note">
                        Due before @dteClosingSoonCutoffUtc.ToLocalTime().ToString("dd MMM")
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="jobs-summary-card jobs-summary-card-info">
                <span class="material-symbols-outlined">emoji_events</span>

                <div>
                    <small>Won shown</small>
                    <strong>@intWonJobs</strong>
                    <span class="jobs-summary-note">
                        @FormatMoney(dcmWonValue) won value
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (blnShowErrorAlert && !String.IsNullOrWhiteSpace(strErrorMessage))
    {
        <div class="alert alert-danger jobs-alert" role="alert">
            <span class="material-symbols-outlined">error</span>

            <div class="alert-content">
                <strong class="alert-title">Unable to load jobs</strong>
                <p>@strErrorMessage</p>
            </div>

            <div class="alert-actions">
                <button class="btn btn-soft-danger btn-sm" type="button" @onclick="LoadJobsAsync">
                    <span class="material-symbols-outlined">refresh</span>
                    Try again
                </button>

                <button class="btn btn-soft-danger btn-sm jobs-alert-close" type="button" @onclick="DismissErrorAlert">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
        </div>
    }

    <div class="crm-card">
        <div class="crm-card-header">
            <div>
                <h3>Job records</h3>
                <p>@strResultSummary</p>
            </div>

            @if (HasActiveFilters)
            {
                <button class="btn btn-soft-secondary btn-sm" type="button" @onclick="ClearFiltersAsync">
                    <span class="material-symbols-outlined">filter_alt_off</span>
                    Clear filters
                </button>
            }
        </div>

        @if (blnLoading)
        {
            <div class="crm-loading">
                <span class="spinner-border spinner-border-sm"></span>
                Loading jobs...
            </div>
        }
        else if (!colJobs.Any())
        {
            <div class="crm-empty-state">
                <span class="material-symbols-outlined">empty_dashboard</span>
                <h4>No jobs found</h4>
                <p>Create your first job or adjust the filters.</p>

                <a class="btn btn-primary" href="/jobs/add">
                    <span class="material-symbols-outlined">add_circle</span>
                    Add job
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle crm-table jobs-table">
                    <thead>
                        <tr>
                            <th>Job</th>
                            <th>Company</th>
                            <th>Contact</th>
                            <th>Stage</th>
                            <th>Value</th>
                            <th>Close date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (Job objJob in colJobs)
                        {
                            <tr class="@GetJobRowClass(objJob)">
                                <td>
                                    <div class="jobs-job-cell">
                                        <div class="jobs-avatar">
                                            @GetJobInitial(objJob)
                                        </div>

                                        <div>
                                            <a class="jobs-name-link" href="@GetJobUrl(objJob.Id)">
                                                @objJob.Name
                                            </a>

                                            @if (!String.IsNullOrWhiteSpace(objJob.Source))
                                            {
                                                <small class="d-block text-muted">
                                                    Source: @objJob.Source
                                                </small>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    @if (objJob.Company != null)
                                    {
                                        <a class="jobs-company-link" href="@GetCompanyUrl(objJob.Company.Id)">
                                            @objJob.Company.Name
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not linked</span>
                                    }
                                </td>

                                <td>
                                    @if (objJob.Contact != null)
                                    {
                                        <a class="jobs-contact-link" href="@GetContactUrl(objJob.Contact.Id)">
                                            @objJob.Contact.Entity.DisplayName
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not linked</span>
                                    }
                                </td>

                                <td>
                                    <span class="@GetStageBadgeClass(objJob.Stage)">
                                        @objJob.Stage.GetDisplay().Name
                                    </span>
                                </td>

                                <td>@FormatMoney(objJob.Value)</td>

                                <td>
                                    <span class="@GetCloseDateClass(objJob)">
                                        @FormatDate(objJob.ExpectedCloseDateUtc)
                                    </span>
                                </td>

                                <td>
                                    @if (objJob.IsArchived)
                                    {
                                        <span class="badge text-bg-secondary">Archived</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">Active</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="jobs-row-actions">
                                        <a href="@GetJobUrl(objJob.Id)" class="btn btn-soft-primary btn-sm">
                                            <span class="material-symbols-outlined">visibility</span>
                                            View
                                        </a>

                                        <a href="@($"/jobs/{objJob.Id}/edit")" class="btn btn-soft-secondary btn-sm">
                                            <span class="material-symbols-outlined">edit</span>
                                            Edit
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@code {
    private List<Job> colJobs = [];

    private String? strSearch;
    private String? strErrorMessage;
    private String strSelectedStage = String.Empty;
    private String strResultSummary = "Showing active job records.";

    private Boolean blnIncludeArchived;
    private Boolean blnLoading = true;
    private Boolean blnShowErrorAlert = true;

    private Int32 intTotalJobs;
    private Int32 intActiveJobs;
    private Int32 intArchivedJobs;
    private Int32 intOpenJobs;
    private Int32 intClosingSoonJobs;
    private Int32 intWonJobs;

    private Decimal dcmOpenPipelineValue;
    private Decimal dcmWonValue;

    private DateTime dteClosingSoonCutoffUtc = DateTime.UtcNow.Date.AddDays(30);

    private Boolean HasActiveFilters =>
        !String.IsNullOrWhiteSpace(strSearch) ||
        !String.IsNullOrWhiteSpace(strSelectedStage) ||
        blnIncludeArchived;

    private JobStage? SelectedStage
    {
        get
        {
            if (Enum.TryParse(strSelectedStage, out JobStage enmStage))
            {
                return enmStage;
            }

            return null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        HeaderState.SetHeader(
            "Jobs",
            "Track deals, pipeline value and expected close dates.",
            GetHeaderActions());

        await LoadJobsAsync();
    }

    private RenderFragment GetHeaderActions()
    {
        return @<a class="btn btn-primary" href="/jobs/add">
            <span class="material-symbols-outlined">add_circle</span>
            Add job
        </a>;
    }

    private Task SearchAsync()
    {
        return LoadJobsAsync();
    }

    private async Task LoadJobsAsync()
    {
        blnLoading = true;
        strErrorMessage = null;
        blnShowErrorAlert = true;

        try
        {
            colJobs = await JobService.GetJobsAsync(
                strSearch,
                SelectedStage,
                null,
                blnIncludeArchived,
                false);

            SetJobStats();
            SetResultSummary();
        }
        catch (Exception objError)
        {
            strErrorMessage = "We couldn’t retrieve the job records right now. " + objError.Message;

            colJobs = [];

            intTotalJobs = 0;
            intActiveJobs = 0;
            intArchivedJobs = 0;
            intOpenJobs = 0;
            intClosingSoonJobs = 0;
            intWonJobs = 0;
            dcmOpenPipelineValue = 0;
            dcmWonValue = 0;

            SetResultSummary();
        }
        finally
        {
            blnLoading = false;
        }
    }

    private async Task ClearFiltersAsync()
    {
        strSearch = null;
        strSelectedStage = String.Empty;
        blnIncludeArchived = false;

        await LoadJobsAsync();
    }

    private void DismissErrorAlert()
    {
        blnShowErrorAlert = false;
    }

    private void SetJobStats()
    {
        DateTime dteTodayUtc = DateTime.UtcNow.Date;
        dteClosingSoonCutoffUtc = dteTodayUtc.AddDays(30);

        intTotalJobs = colJobs.Count;

        intArchivedJobs = colJobs.Count(objJob =>
            objJob.Entity.ArchivedUtc.HasValue);

        intActiveJobs = colJobs.Count(objJob =>
            !objJob.Entity.ArchivedUtc.HasValue);

        intOpenJobs = colJobs.Count(IsOpenJob);

        dcmOpenPipelineValue = colJobs
            .Where(IsOpenJob)
            .Sum(objJob => objJob.Value ?? 0);

        intClosingSoonJobs = colJobs.Count(objJob =>
            IsOpenJob(objJob) &&
            objJob.ExpectedCloseDateUtc.HasValue &&
            objJob.ExpectedCloseDateUtc.Value.Date >= dteTodayUtc &&
            objJob.ExpectedCloseDateUtc.Value.Date <= dteClosingSoonCutoffUtc);

        intWonJobs = colJobs.Count(objJob =>
            !objJob.Entity.ArchivedUtc.HasValue &&
            objJob.Stage == JobStage.Paid);

        dcmWonValue = colJobs
            .Where(objJob =>
                !objJob.Entity.ArchivedUtc.HasValue &&
                objJob.Stage == JobStage.Paid)
            .Sum(objJob => objJob.Value ?? 0);
    }

    private void SetResultSummary()
    {
        List<String> colFilters = [];

        if (!String.IsNullOrWhiteSpace(strSearch))
        {
            colFilters.Add($"matching \"{strSearch}\"");
        }

        if (SelectedStage.HasValue)
        {
            colFilters.Add($"in {SelectedStage.Value.GetDisplay().Name}");
        }

        if (blnIncludeArchived)
        {
            colFilters.Add("including archived");
        }

        if (!colFilters.Any())
        {
            strResultSummary = $"Showing {intTotalJobs} job record{GetPlural(intTotalJobs)}.";
            return;
        }

        strResultSummary = $"Showing {intTotalJobs} result{GetPlural(intTotalJobs)} {String.Join(", ", colFilters)}.";
    }

    private static Boolean IsOpenJob(Job objJob)
    {
        return !objJob.Entity.ArchivedUtc.HasValue &&
               objJob.Stage != JobStage.Paid &&
               objJob.Stage != JobStage.Lost;
    }

    private static String GetPlural(Int32 intCount)
    {
        return intCount == 1 ? String.Empty : "s";
    }

    private static String GetJobUrl(Guid objJobId)
    {
        return $"/jobs/{objJobId}";
    }

    private static String GetCompanyUrl(Guid objCompanyId)
    {
        return $"/companies/{objCompanyId}";
    }

    private static String GetContactUrl(Guid objContactId)
    {
        return $"/contacts/{objContactId}";
    }

    private static String GetJobInitial(Job objJob)
    {
        if (String.IsNullOrWhiteSpace(objJob.Name))
        {
            return "?";
        }

        return objJob.Name.Trim().Substring(0, 1).ToUpperInvariant();
    }

    private static String GetStageBadgeClass(JobStage enmStage)
    {
        return enmStage switch
        {
            JobStage.New => "job-stage job-stage-new",
            JobStage.Lost => "job-stage job-stage-lost",
            JobStage.Quoted => "job-stage job-stage-quoted",
            JobStage.ToDo => "job-stage job-stage-todo",
            JobStage.Paid => "job-stage job-stage-paid",
            _ => "job-stage"
        };
    }

    private static String GetCloseDateClass(Job objJob)
    {
        if (!IsOpenJob(objJob) || !objJob.ExpectedCloseDateUtc.HasValue)
        {
            return String.Empty;
        }

        DateTime dteTodayUtc = DateTime.UtcNow.Date;
        DateTime dteCloseDateUtc = objJob.ExpectedCloseDateUtc.Value.Date;

        if (dteCloseDateUtc < dteTodayUtc)
        {
            return "jobs-close-date-overdue";
        }

        if (dteCloseDateUtc <= dteTodayUtc.AddDays(30))
        {
            return "jobs-close-date-soon";
        }

        return String.Empty;
    }

    private static String FormatMoney(Decimal dcmValue)
    {
        return dcmValue.ToString("C0");
    }

    private static String FormatMoney(Decimal? dcmValue)
    {
        if (!dcmValue.HasValue)
        {
            return "—";
        }

        return dcmValue.Value.ToString("C0");
    }

    private static String FormatDate(DateTime? dteDate)
    {
        if (!dteDate.HasValue)
        {
            return "—";
        }

        return dteDate.Value.ToLocalTime().ToString("dd MMM yyyy");
    }

    private static String GetJobRowClass(Job objJob)
    {
        if (objJob.Entity.ArchivedUtc.HasValue)
        {
            return "jobs-row-archived";
        }

        if (objJob.Stage == JobStage.Lost)
        {
            return "jobs-row-muted";
        }

        return String.Empty;
    }
}