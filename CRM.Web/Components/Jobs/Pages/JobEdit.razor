@page "/jobs/add"
@page "/jobs/{JobId:guid}/edit"
@attribute [Authorize]
@rendermode InteractiveServer

@using CRM.Core.Companies.Abstractions
@using CRM.Core.Companies.Domain
@using CRM.Core.Contacts.Abstractions
@using CRM.Core.Contacts.Domain
@using CRM.Core.Jobs.Abstractions
@using CRM.Core.Jobs.Domain
@using CRM.Web.State

@inject IJobService JobService
@inject ICompanyService CompanyService
@inject IContactService ContactService
@inject NavigationManager Navigation
@inject PageHeaderState HeaderState

<PageTitle>@strPageTitle</PageTitle>

<section class="job-edit-page">
    <div class="job-toolbar">
        <button type="button" class="btn crm-btn-secondary" @onclick="GoBack">
            <span class="material-symbols-outlined">arrow_back</span>
            @(blnEditMode ? "Back to job" : "Back to jobs")
        </button>
    </div>

    @if (!String.IsNullOrWhiteSpace(strErrorMessage))
    {
        <div class="alert alert-danger crm-alert" role="alert">
            <span class="material-symbols-outlined">error</span>
            <div>@strErrorMessage</div>
        </div>
    }

    @if (blnLoading)
    {
        <div class="crm-card job-empty-state">
            <span class="material-symbols-outlined">hourglass_empty</span>
            <h2>Loading job</h2>
            <p>Please wait while the form is prepared.</p>
        </div>
    }
    else
    {
        <EditForm Model="objJob" OnValidSubmit="SaveJobAsync" FormName="JobEditForm">
            <DataAnnotationsValidator />

            <div class="job-layout">
                <div class="job-main-column">
                    <div class="crm-card job-form-card">
                        <h2>@(blnEditMode ? "Edit job" : "New job")</h2>
                        <p>Track the deal, company, contact and pipeline stage.</p>

                        <div class="row g-3 mt-1">
                            <div class="col-md-8">
                                <label class="form-label" for="name">Name</label>
                                <InputText id="name" class="form-control" @bind-Value="objJob.Name" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="stage">Stage</label>
                                <InputSelect id="stage" class="form-select" TValue="JobStage" @bind-Value="objJob.Stage">
                                    @foreach (JobStage enmStage in Enum.GetValues<JobStage>())
                                    {
                                        <option value="@enmStage">@GetStageName(enmStage)</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label" for="company">Company</label>
                                <select id="company" class="form-select" @bind="strSelectedCompanyId">
                                    <option value="">No company linked</option>

                                    @foreach (Company objCompany in colCompanies)
                                    {
                                        <option value="@objCompany.Id.ToString()">@objCompany.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label" for="contact">Contact</label>
                                <select id="contact" class="form-select" @bind="strSelectedContactId">
                                    <option value="">No contact linked</option>

                                    @foreach (Contact objContact in colContacts)
                                    {
                                        <option value="@objContact.Id.ToString()">@objContact.Entity.DisplayName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="value">Value</label>
                                <InputNumber id="value" class="form-control" @bind-Value="objJob.Value" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="probability">Probability %</label>
                                <InputNumber id="probability" class="form-control" @bind-Value="objJob.ProbabilityPercent" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label" for="closeDate">Expected close date</label>
                                <InputDate id="closeDate" class="form-control" @bind-Value="objJob.ExpectedCloseDateUtc" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label" for="source">Source</label>
                                <InputText id="source" class="form-control" @bind-Value="objJob.Source" />
                            </div>

                            <div class="col-12">
                                <label class="form-label" for="description">Description</label>
                                <InputTextArea id="description" class="form-control job-textarea" @bind-Value="objJob.Description" />
                            </div>

                            <div class="col-12">
                                <label class="form-label" for="notes">Notes</label>
                                <InputTextArea id="notes" class="form-control job-textarea" @bind-Value="objJob.Notes" />
                            </div>
                        </div>
                    </div>

                    <div class="job-save-bar">
                        <button type="button" class="btn crm-btn-secondary" disabled="@blnSaving" @onclick="GoBack">
                            Cancel
                        </button>

                        <button type="submit" class="btn crm-btn-primary" disabled="@blnSaving">
                            <span class="material-symbols-outlined">save</span>
                            @(blnSaving ? "Saving..." : "Save job")
                        </button>
                    </div>
                </div>

                <aside class="job-side-column">
                    <div class="crm-card job-summary-card">
                        <h3>Preview</h3>

                        <dl>
                            <div>
                                <dt>Stage</dt>
                                <dd>@GetStageName(objJob.Stage)</dd>
                            </div>

                            <div>
                                <dt>Value</dt>
                                <dd>@FormatMoney(objJob.Value)</dd>
                            </div>

                            <div>
                                <dt>Probability</dt>
                                <dd>@FormatProbability(objJob.ProbabilityPercent)</dd>
                            </div>

                            <div>
                                <dt>Close</dt>
                                <dd>@FormatDate(objJob.ExpectedCloseDateUtc)</dd>
                            </div>
                        </dl>
                    </div>
                </aside>
            </div>
        </EditForm>
    }
</section>

@code {
    [Parameter]
    public Guid? JobId { get; set; }

    [SupplyParameterFromQuery(Name = "companyId")]
    public Guid? CompanyId { get; set; }

    [SupplyParameterFromQuery(Name = "contactId")]
    public Guid? ContactId { get; set; }

    private Job objJob = new();
    private List<Company> colCompanies = [];
    private List<Contact> colContacts = [];

    private String strPageTitle = "New job";
    private String? strErrorMessage;
    private Boolean blnLoading = true;
    private Boolean blnSaving;

    private Boolean blnEditMode => JobId.HasValue && JobId.Value != Guid.Empty;

    private String strSelectedCompanyId
    {
        get => objJob.CompanyId?.ToString() ?? String.Empty;
        set
        {
            objJob.CompanyId = Guid.TryParse(value, out Guid objCompanyId)
                ? objCompanyId
                : null;
        }
    }

    private String strSelectedContactId
    {
        get => objJob.ContactId?.ToString() ?? String.Empty;
        set
        {
            objJob.ContactId = Guid.TryParse(value, out Guid objContactId)
                ? objContactId
                : null;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        blnLoading = true;
        strErrorMessage = null;

        try
        {
            colCompanies = await CompanyService.GetCompaniesAsync();
            colContacts = await ContactService.GetContactsAsync();

            if (blnEditMode)
            {
                Job? objExistingJob = await JobService.GetJobByIdAsync(JobId!.Value);

                if (objExistingJob == null)
                {
                    strErrorMessage = "Job not found.";
                    HeaderState.SetHeader("Job not found", "The selected job could not be loaded");
                    return;
                }

                objJob = objExistingJob;
                strPageTitle = "Edit " + objJob.Name;
                HeaderState.SetHeader("Edit job", objJob.Name);
            }
            else
            {
                objJob = new Job
                {
                    CompanyId = CompanyId,
                    ContactId = ContactId,
                    Stage = JobStage.New
                };

                strPageTitle = "New job";
                HeaderState.SetHeader("New job", "Create a new sales job");
            }
        }
        catch (Exception objError)
        {
            strErrorMessage = "Failed to load job form: " + objError.Message;
        }
        finally
        {
            blnLoading = false;
        }
    }

    private async Task SaveJobAsync()
    {
        blnSaving = true;
        strErrorMessage = null;

        try
        {
            Job objSavedJob;

            if (blnEditMode)
            {
                Job? objUpdatedJob = await JobService.UpdateJobAsync(objJob);

                if (objUpdatedJob == null)
                {
                    strErrorMessage = "The job could not be updated.";
                    return;
                }

                objSavedJob = objUpdatedJob;
            }
            else
            {
                objSavedJob = await JobService.AddJobAsync(objJob);
            }

            Navigation.NavigateTo($"/jobs/{objSavedJob.Id}");
        }
        catch (Exception objError)
        {
            strErrorMessage = "Failed to save job: " + objError.Message;
        }
        finally
        {
            blnSaving = false;
        }
    }

    private void GoBack()
    {
        if (blnEditMode)
        {
            Navigation.NavigateTo($"/jobs/{JobId}");
            return;
        }

        Navigation.NavigateTo("/jobs");
    }

    private static String GetStageName(JobStage enmStage)
    {
        return enmStage switch
        {
            JobStage.New => "New",
            JobStage.Quoted => "Quoted",
            JobStage.ToDo => "To Do",
            JobStage.Invoiced => "Invoiced",
            JobStage.Paid => "Paid",
            JobStage.Lost => "Lost",
            _ => enmStage.ToString()
        };
    }

    private static String FormatMoney(Decimal? dcmValue)
    {
        return dcmValue.HasValue ? dcmValue.Value.ToString("C0") : "Not set";
    }

    private static String FormatProbability(Int32? intProbability)
    {
        return intProbability.HasValue ? $"{intProbability.Value}%" : "Not set";
    }

    private static String FormatDate(DateTime? dteDate)
    {
        return dteDate.HasValue ? dteDate.Value.ToLocalTime().ToString("dd MMM yyyy") : "Not set";
    }
}